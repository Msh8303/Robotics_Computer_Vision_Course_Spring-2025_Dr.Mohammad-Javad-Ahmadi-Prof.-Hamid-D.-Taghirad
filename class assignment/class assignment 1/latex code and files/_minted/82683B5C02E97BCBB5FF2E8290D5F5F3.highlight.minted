\PYG{c+c1}{\PYGZsh{} solver=\PYGZsq{}lbfgs\PYGZsq{} : بهینه‌سازی که برای داده‌های کم و شبکه‌های کوچک بسیار عالی و همگرا عمل می‌کند}
\PYG{n}{mlp\PYGZus{}model} \PYG{o}{=} \PYG{n}{MLPClassifier}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}layer\PYGZus{}sizes}\PYG{o}{=}\PYG{p}{(}\PYG{l+m+mi}{4}\PYG{p}{,),} 
