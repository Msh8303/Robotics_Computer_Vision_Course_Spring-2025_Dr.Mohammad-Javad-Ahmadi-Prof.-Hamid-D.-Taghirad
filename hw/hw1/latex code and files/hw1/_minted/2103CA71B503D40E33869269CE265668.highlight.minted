        \PYG{p}{[} \PYG{l+m+mf}{0.81379768}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mf}{0.44096961}\PYG{p}{,}  \PYG{l+m+mf}{0.37852231}\PYG{p}{],}
        \PYG{p}{[} \PYG{l+m+mf}{0.46984631}\PYG{p}{,}  \PYG{l+m+mf}{0.88256412}\PYG{p}{,}  \PYG{l+m+mf}{0.01802831}\PYG{p}{],}
        \PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mf}{0.34202014}\PYG{p}{,}  \PYG{l+m+mf}{0.16317591}\PYG{p}{,}  \PYG{l+m+mf}{0.92541658}\PYG{p}{]}
    \PYG{p}{])}

    \PYG{c+c1}{\PYGZsh{} 2. Gimbal lock example (beta = +pi/2 → r31 = \PYGZhy{}1)}
    \PYG{n}{R\PYGZus{}gimbal\PYGZus{}pos} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{array}\PYG{p}{([}
        \PYG{p}{[} \PYG{l+m+mf}{0.0}\PYG{p}{,}  \PYG{l+m+mf}{0.0}\PYG{p}{,}  \PYG{l+m+mf}{1.0}\PYG{p}{],}
        \PYG{p}{[} \PYG{l+m+mf}{0.0}\PYG{p}{,}  \PYG{l+m+mf}{1.0}\PYG{p}{,}  \PYG{l+m+mf}{0.0}\PYG{p}{],}
        \PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mf}{1.0}\PYG{p}{,}  \PYG{l+m+mf}{0.0}\PYG{p}{,}  \PYG{l+m+mf}{0.0}\PYG{p}{]}
    \PYG{p}{])}

    \PYG{k}{for} \PYG{n}{name}\PYG{p}{,} \PYG{n}{R} \PYG{o+ow}{in} \PYG{p}{[}
        \PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Normal\PYGZdq{}}\PYG{p}{,} \PYG{n}{R\PYGZus{}normal}\PYG{p}{),}
        \PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Gimbal Lock (+pi/2)\PYGZdq{}}\PYG{p}{,} \PYG{n}{R\PYGZus{}gimbal\PYGZus{}pos}\PYG{p}{)}
    \PYG{p}{]:}
        \PYG{n}{alpha}\PYG{p}{,} \PYG{n}{beta}\PYG{p}{,} \PYG{n}{gamma}\PYG{p}{,} \PYG{n}{mode} \PYG{o}{=} \PYG{n}{rotation\PYGZus{}matrix\PYGZus{}to\PYGZus{}euler}\PYG{p}{(}\PYG{n}{R}\PYG{p}{)}

        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Test Case: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{name}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZdq{}}\PYG{p}{)}
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Mode:  }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{mode}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Alpha: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{math}\PYG{o}{.}\PYG{n}{degrees}\PYG{p}{(}\PYG{n}{alpha}\PYG{p}{)}\PYG{l+s+si}{:}\PYG{l+s+s2}{.2f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ deg\PYGZdq{}}\PYG{p}{)}
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Beta:  }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{math}\PYG{o}{.}\PYG{n}{degrees}\PYG{p}{(}\PYG{n}{beta}\PYG{p}{)}\PYG{l+s+si}{:}\PYG{l+s+s2}{.2f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ deg\PYGZdq{}}\PYG{p}{)}
