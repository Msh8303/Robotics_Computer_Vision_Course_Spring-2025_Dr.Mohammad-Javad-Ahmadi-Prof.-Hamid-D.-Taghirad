\PYG{c+c1}{\PYGZsh{} how often tools are used together}
\PYG{n}{co} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n}{N}\PYG{p}{,} \PYG{n}{N}\PYG{p}{),} \PYG{n}{dtype}\PYG{o}{=}\PYG{n+nb}{int}\PYG{p}{)}
\PYG{n}{label\PYGZus{}mat} \PYG{o}{=} \PYG{n}{dfs}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}train\PYGZdq{}}\PYG{p}{][}\PYG{n}{CLASS\PYGZus{}COLS}\PYG{p}{]}\PYG{o}{.}\PYG{n}{values}

\PYG{c+c1}{\PYGZsh{} loop that repeats for all imgs (rows of the .csv)}
\PYG{k}{for} \PYG{n}{row} \PYG{o+ow}{in} \PYG{n}{label\PYGZus{}mat}\PYG{p}{:}
