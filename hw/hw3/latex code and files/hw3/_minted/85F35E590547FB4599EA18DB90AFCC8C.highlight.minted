\PYG{n}{co\PYGZus{}df} \PYG{o}{=} \PYG{n}{pd}\PYG{o}{.}\PYG{n}{DataFrame}\PYG{p}{(}\PYG{n}{co}\PYG{p}{,} \PYG{n}{index}\PYG{o}{=}\PYG{n}{CLASS\PYGZus{}COLS}\PYG{p}{,} \PYG{n}{columns}\PYG{o}{=}\PYG{n}{CLASS\PYGZus{}COLS}\PYG{p}{)}

