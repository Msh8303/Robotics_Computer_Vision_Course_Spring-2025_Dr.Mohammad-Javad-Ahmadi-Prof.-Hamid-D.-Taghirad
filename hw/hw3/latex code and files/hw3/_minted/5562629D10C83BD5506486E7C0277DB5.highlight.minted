\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}\PYGZsh{}Hyperparameter Optimization Using Optuna Framework\PYGZdq{}\PYGZdq{}\PYGZdq{}}

\PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{optuna}
\PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{gc}
\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{objective}\PYG{p}{(}\PYG{n}{trial}\PYG{p}{):}
