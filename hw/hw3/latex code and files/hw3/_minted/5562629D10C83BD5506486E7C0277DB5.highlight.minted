    \PYG{n}{optimizer\PYGZus{}name} \PYG{o}{=} \PYG{n}{trial}\PYG{o}{.}\PYG{n}{suggest\PYGZus{}categorical}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}optimizer\PYGZdq{}}\PYG{p}{,} \PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}AdamW\PYGZdq{}}\PYG{p}{,} \PYG{l+s+s2}{\PYGZdq{}SGD\PYGZdq{}}\PYG{p}{])}
    \PYG{n}{weight\PYGZus{}decay} \PYG{o}{=} \PYG{n}{trial}\PYG{o}{.}\PYG{n}{suggest\PYGZus{}float}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}weight\PYGZus{}decay\PYGZdq{}}\PYG{p}{,} \PYG{l+m+mf}{1e\PYGZhy{}6}\PYG{p}{,} \PYG{l+m+mf}{1e\PYGZhy{}3}\PYG{p}{)}


    \PYG{n}{model} \PYG{o}{=} \PYG{n}{models}\PYG{o}{.}\PYG{n}{efficientnet\PYGZus{}b3}\PYG{p}{(}\PYG{n}{weights}\PYG{o}{=}\PYG{n}{models}\PYG{o}{.}\PYG{n}{EfficientNet\PYGZus{}B3\PYGZus{}Weights}\PYG{o}{.}\PYG{n}{IMAGENET1K\PYGZus{}V1}\PYG{p}{)}
    \PYG{n}{num\PYGZus{}ftrs} \PYG{o}{=} \PYG{n}{model}\PYG{o}{.}\PYG{n}{classifier}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{o}{.}\PYG{n}{in\PYGZus{}features}
    \PYG{n}{model}\PYG{o}{.}\PYG{n}{classifier}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{num\PYGZus{}ftrs}\PYG{p}{,} \PYG{l+m+mi}{12}\PYG{p}{)}
    \PYG{n}{model} \PYG{o}{=} \PYG{n}{model}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{)}


    \PYG{k}{if} \PYG{n}{optimizer\PYGZus{}name} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}AdamW\PYGZdq{}}\PYG{p}{:}
