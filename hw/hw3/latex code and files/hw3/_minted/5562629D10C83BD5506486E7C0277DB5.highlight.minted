    \PYG{n}{criterion} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{BCEWithLogitsLoss}\PYG{p}{()}


    \PYG{n}{model}\PYG{o}{.}\PYG{n}{train}\PYG{p}{()}

    \PYG{k}{for} \PYG{n}{batch\PYGZus{}idx}\PYG{p}{,} \PYG{p}{(}\PYG{n}{data}\PYG{p}{,} \PYG{n}{target}\PYG{p}{)} \PYG{o+ow}{in} \PYG{n+nb}{enumerate}\PYG{p}{(}\PYG{n}{train\PYGZus{}loader}\PYG{p}{):}
        \PYG{k}{if} \PYG{n}{batch\PYGZus{}idx} \PYG{o}{\PYGZgt{}} \PYG{l+m+mi}{30}\PYG{p}{:} \PYG{k}{break}
        \PYG{n}{data}\PYG{p}{,} \PYG{n}{target} \PYG{o}{=} \PYG{n}{data}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{),} \PYG{n}{target}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{)}
        \PYG{n}{optimizer}\PYG{o}{.}\PYG{n}{zero\PYGZus{}grad}\PYG{p}{()}
        \PYG{n}{output} \PYG{o}{=} \PYG{n}{model}\PYG{p}{(}\PYG{n}{data}\PYG{p}{)}
        \PYG{n}{loss} \PYG{o}{=} \PYG{n}{criterion}\PYG{p}{(}\PYG{n}{output}\PYG{p}{,} \PYG{n}{target}\PYG{p}{)}
        \PYG{n}{loss}\PYG{o}{.}\PYG{n}{backward}\PYG{p}{()}
        \PYG{n}{optimizer}\PYG{o}{.}\PYG{n}{step}\PYG{p}{()}


    \PYG{n}{model}\PYG{o}{.}\PYG{n}{eval}\PYG{p}{()}
    \PYG{n}{val\PYGZus{}loss} \PYG{o}{=} \PYG{l+m+mi}{0}
    \PYG{n}{val\PYGZus{}loader} \PYG{o}{=} \PYG{n}{DataLoader}\PYG{p}{(}\PYG{n}{val\PYGZus{}dataset}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{32}\PYG{p}{)}
    \PYG{k}{with} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{no\PYGZus{}grad}\PYG{p}{():}
        \PYG{k}{for} \PYG{n}{data}\PYG{p}{,} \PYG{n}{target} \PYG{o+ow}{in} \PYG{n}{val\PYGZus{}loader}\PYG{p}{:}
            \PYG{n}{data}\PYG{p}{,} \PYG{n}{target} \PYG{o}{=} \PYG{n}{data}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{),} \PYG{n}{target}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{)}
            \PYG{n}{output} \PYG{o}{=} \PYG{n}{model}\PYG{p}{(}\PYG{n}{data}\PYG{p}{)}
            \PYG{n}{val\PYGZus{}loss} \PYG{o}{+=} \PYG{n}{criterion}\PYG{p}{(}\PYG{n}{output}\PYG{p}{,} \PYG{n}{target}\PYG{p}{)}\PYG{o}{.}\PYG{n}{item}\PYG{p}{()}

    \PYG{k}{return} \PYG{n}{val\PYGZus{}loss} \PYG{o}{/} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{val\PYGZus{}loader}\PYG{p}{)}


\PYG{n}{study} \PYG{o}{=} \PYG{n}{optuna}\PYG{o}{.}\PYG{n}{create\PYGZus{}study}\PYG{p}{(}\PYG{n}{direction}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}minimize\PYGZdq{}}\PYG{p}{)}
\PYG{n}{study}\PYG{o}{.}\PYG{n}{optimize}\PYG{p}{(}\PYG{n}{objective}\PYG{p}{,} \PYG{n}{n\PYGZus{}trials}\PYG{o}{=}\PYG{l+m+mi}{5}\PYG{p}{)}

\PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Best hyperParametrs:\PYGZdq{}}\PYG{p}{,} \PYG{n}{study}\PYG{o}{.}\PYG{n}{best\PYGZus{}params}\PYG{p}{)}

\PYG{n}{best\PYGZus{}params} \PYG{o}{=} \PYG{n}{study}\PYG{o}{.}\PYG{n}{best\PYGZus{}params}
\PYG{n}{model} \PYG{o}{=} \PYG{n}{models}\PYG{o}{.}\PYG{n}{efficientnet\PYGZus{}b3}\PYG{p}{(}\PYG{n}{weights}\PYG{o}{=}\PYG{n}{models}\PYG{o}{.}\PYG{n}{EfficientNet\PYGZus{}B3\PYGZus{}Weights}\PYG{o}{.}\PYG{n}{IMAGENET1K\PYGZus{}V1}\PYG{p}{)}
\PYG{n}{num\PYGZus{}ftrs} \PYG{o}{=} \PYG{n}{model}\PYG{o}{.}\PYG{n}{classifier}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{o}{.}\PYG{n}{in\PYGZus{}features}
\PYG{n}{model}\PYG{o}{.}\PYG{n}{classifier}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{Linear}\PYG{p}{(}\PYG{n}{num\PYGZus{}ftrs}\PYG{p}{,} \PYG{l+m+mi}{12}\PYG{p}{)}
\PYG{n}{model} \PYG{o}{=} \PYG{n}{model}\PYG{o}{.}\PYG{n}{to}\PYG{p}{(}\PYG{n}{device}\PYG{p}{)}

\PYG{k}{if} \PYG{n}{best\PYGZus{}params}\PYG{p}{[}\PYG{l+s+s1}{\PYGZsq{}optimizer\PYGZsq{}}\PYG{p}{]} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}AdamW\PYGZdq{}}\PYG{p}{:}
