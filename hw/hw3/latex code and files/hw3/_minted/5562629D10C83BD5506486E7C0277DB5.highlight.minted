        \PYG{n}{focal\PYGZus{}loss} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{alpha} \PYG{o}{*} \PYG{p}{(}\PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{pt}\PYG{p}{)}\PYG{o}{**}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{gamma} \PYG{o}{*} \PYG{n}{bce\PYGZus{}loss}

        \PYG{k}{if} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{reduction} \PYG{o}{==} \PYG{l+s+s1}{\PYGZsq{}mean\PYGZsq{}}\PYG{p}{:}
            \PYG{k}{return} \PYG{n}{focal\PYGZus{}loss}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{()}
        \PYG{k}{else}\PYG{p}{:}
            \PYG{k}{return} \PYG{n}{focal\PYGZus{}loss}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{()}

