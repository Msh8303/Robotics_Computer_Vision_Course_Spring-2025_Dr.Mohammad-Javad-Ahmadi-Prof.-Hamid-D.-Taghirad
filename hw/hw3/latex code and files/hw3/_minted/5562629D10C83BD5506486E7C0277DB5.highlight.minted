    \PYG{l+s+s1}{\PYGZsq{}train\PYGZus{}acc\PYGZsq{}}\PYG{p}{:} \PYG{p}{[],} \PYG{l+s+s1}{\PYGZsq{}val\PYGZus{}acc\PYGZsq{}}\PYG{p}{:} \PYG{p}{[]}
\PYG{p}{\PYGZcb{}}

\PYG{n}{epochs} \PYG{o}{=} \PYG{l+m+mi}{10}

