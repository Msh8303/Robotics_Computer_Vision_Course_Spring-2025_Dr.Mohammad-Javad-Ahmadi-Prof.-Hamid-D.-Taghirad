\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Find the 4 black square calibration markers.}
\PYG{l+s+sd}{    Returns: corners array sorted [TL, TR, BR, BL]}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}

    \PYG{c+c1}{\PYGZsh{} brg \PYGZhy{}\PYGZhy{}\PYGZgt{} hsv}
