\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{sort\PYGZus{}clockwise}\PYG{p}{(}\PYG{n}{pts}\PYG{p}{):}

    \PYG{n}{pts} \PYG{o}{=} \PYG{n+nb}{sorted}\PYG{p}{(}\PYG{n}{pts}\PYG{p}{,} \PYG{n}{key}\PYG{o}{=}\PYG{k}{lambda} \PYG{n}{p}\PYG{p}{:} \PYG{n}{p}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{])}

