\PYG{c+c1}{\PYGZsh{} load image}
\PYG{n}{image\PYGZus{}path} \PYG{o}{=} \PYG{l+s+sa}{r}\PYG{l+s+s2}{\PYGZdq{}C:\PYGZbs{}Users\PYGZbs{}Asus\PYGZbs{}Desktop\PYGZbs{}hasti\PYGZbs{}output.png\PYGZdq{}}   \PYG{c+c1}{\PYGZsh{} change to your image path}
