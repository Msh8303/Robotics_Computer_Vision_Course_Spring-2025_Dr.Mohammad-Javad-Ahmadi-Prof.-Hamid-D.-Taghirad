    \PYG{n}{c\PYGZus{}alpha} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{cos}\PYG{p}{(}\PYG{n}{alpha}\PYG{p}{)}
    \PYG{n}{s\PYGZus{}alpha} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sin}\PYG{p}{(}\PYG{n}{alpha}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} MDH Transformation Matrix elements}
    \PYG{n}{T} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{array}\PYG{p}{([}
        \PYG{p}{[}\PYG{n}{c\PYGZus{}theta}\PYG{p}{,}            \PYG{o}{\PYGZhy{}}\PYG{n}{s\PYGZus{}theta}\PYG{p}{,}            \PYG{l+m+mi}{0}\PYG{p}{,}        \PYG{n}{a}\PYG{p}{],}
