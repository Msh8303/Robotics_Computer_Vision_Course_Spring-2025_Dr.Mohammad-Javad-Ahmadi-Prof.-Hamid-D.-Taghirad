        \PYG{c+c1}{\PYGZsh{} T\PYGZus{}0\PYGZca{}n = T\PYGZus{}0\PYGZca{}1 * T\PYGZus{}1\PYGZca{}2 * ... * T\PYGZus{}\PYGZob{}n\PYGZhy{}1\PYGZcb{}\PYGZca{}n}
