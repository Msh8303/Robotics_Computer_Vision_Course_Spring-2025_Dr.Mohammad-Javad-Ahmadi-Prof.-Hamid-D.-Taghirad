\PYG{l+s+sd}{    Calculates the homogeneous transformation matrix for a single link }
\PYG{l+s+sd}{    using the Modified Denavit\PYGZhy{}Hartenberg (MDH / Craig\PYGZsq{}s) convention.}

\PYG{l+s+sd}{    Formula: T = Rot\PYGZus{}x(alpha) * Trans\PYGZus{}x(a) * Rot\PYGZus{}z(theta) * Trans\PYGZus{}z(d)}

\PYG{l+s+sd}{    Parameters:}
\PYG{l+s+sd}{    alpha (float): Link twist angle in radians (alpha\PYGZus{}\PYGZob{}i\PYGZhy{}1\PYGZcb{})}
\PYG{l+s+sd}{    a (float): Link length in meters (a\PYGZus{}\PYGZob{}i\PYGZhy{}1\PYGZcb{})}
\PYG{l+s+sd}{    d (float): Link offset in meters (d\PYGZus{}i)}
\PYG{l+s+sd}{    theta (float): Joint angle in radians (theta\PYGZus{}i)}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{    numpy.ndarray: 4x4 Homogeneous Transformation Matrix (T\PYGZus{}\PYGZob{}i\PYGZhy{}1\PYGZcb{}\PYGZca{}i)}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{c\PYGZus{}theta} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{cos}\PYG{p}{(}\PYG{n}{theta}\PYG{p}{)}
