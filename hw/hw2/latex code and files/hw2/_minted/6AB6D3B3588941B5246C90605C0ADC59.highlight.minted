        \PYG{n}{T\PYGZus{}i} \PYG{o}{=} \PYG{n}{mdh\PYGZus{}transformation\PYGZus{}matrix}\PYG{p}{(}\PYG{n}{alpha}\PYG{p}{,} \PYG{n}{a}\PYG{p}{,} \PYG{n}{d}\PYG{p}{,} \PYG{n}{theta}\PYG{p}{)}

