        \PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{n}{np}\PYG{o}{.}\PYG{n}{pi}\PYG{o}{/}\PYG{l+m+mi}{2}\PYG{p}{,}    \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{n}{t2}\PYG{p}{],}  \PYG{c+c1}{\PYGZsh{} Link 2}
        \PYG{p}{[}\PYG{n}{np}\PYG{o}{.}\PYG{n}{pi}\PYG{o}{/}\PYG{l+m+mi}{2}\PYG{p}{,}     \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{n}{d3}\PYG{p}{,} \PYG{n}{t3}\PYG{p}{],}  \PYG{c+c1}{\PYGZsh{} Link 3}
        \PYG{p}{[}\PYG{n}{np}\PYG{o}{.}\PYG{n}{pi}\PYG{o}{/}\PYG{l+m+mi}{2}\PYG{p}{,}     \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{n}{t4}\PYG{p}{],}  \PYG{c+c1}{\PYGZsh{} Link 4}
        \PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{n}{np}\PYG{o}{.}\PYG{n}{pi}\PYG{o}{/}\PYG{l+m+mi}{2}\PYG{p}{,}    \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{n}{d5}\PYG{p}{,} \PYG{n}{t5}\PYG{p}{],}  \PYG{c+c1}{\PYGZsh{} Link 5}
        \PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{n}{np}\PYG{o}{.}\PYG{n}{pi}\PYG{o}{/}\PYG{l+m+mi}{2}\PYG{p}{,}    \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{n}{t6}\PYG{p}{],}  \PYG{c+c1}{\PYGZsh{} Link 6}
        \PYG{p}{[}\PYG{n}{np}\PYG{o}{.}\PYG{n}{pi}\PYG{o}{/}\PYG{l+m+mi}{2}\PYG{p}{,}     \PYG{l+m+mi}{0}\PYG{p}{,}  \PYG{n}{d7}\PYG{p}{,} \PYG{n}{t7}\PYG{p}{]}   \PYG{c+c1}{\PYGZsh{} Link 7}
    \PYG{p}{]}

    \PYG{c+c1}{\PYGZsh{} Initialize the total transformation matrix as an Identity matrix}
    \PYG{n}{T\PYGZus{}0\PYGZus{}to\PYGZus{}7} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{eye}\PYG{p}{(}\PYG{l+m+mi}{4}\PYG{p}{)}

