        \PYG{p}{[}\PYG{n}{s\PYGZus{}theta} \PYG{o}{*} \PYG{n}{s\PYGZus{}alpha}\PYG{p}{,}   \PYG{n}{c\PYGZus{}theta} \PYG{o}{*} \PYG{n}{s\PYGZus{}alpha}\PYG{p}{,}  \PYG{n}{c\PYGZus{}alpha}\PYG{p}{,}  \PYG{n}{d} \PYG{o}{*} \PYG{n}{c\PYGZus{}alpha}\PYG{p}{],}
        \PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{,}                   \PYG{l+m+mi}{0}\PYG{p}{,}                  \PYG{l+m+mi}{0}\PYG{p}{,}        \PYG{l+m+mi}{1}\PYG{p}{]}
    \PYG{p}{])}

    \PYG{k}{return} \PYG{n}{T}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward\PYGZus{}kinematics}\PYG{p}{(}\PYG{n}{thetas}\PYG{p}{,} \PYG{n}{d\PYGZus{}params}\PYG{p}{):}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Calculates the forward kinematics of the 7\PYGZhy{}DOF robot using the MDH table.}

\PYG{l+s+sd}{    Parameters:}
\PYG{l+s+sd}{    thetas (list or array): List of 7 joint angles [theta1, theta2, ..., theta7] in radians.}
\PYG{l+s+sd}{    d\PYGZus{}params (list or array): List of d offsets [d1, d3, d5, d7] in meters. }
\PYG{l+s+sd}{                              (d2, d4, d6 are zero based on the table).}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{    numpy.ndarray: Final 4x4 Transformation Matrix from Base (Frame 0) to End\PYGZhy{}Effector (Frame 7).}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
